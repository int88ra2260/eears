        "used_by": ["server.js"]
      },
      "surveySettingsRouter.js": {
        "imports": ["../models", "../middlewares/auth"],
        "exports": [
          "GET /api/admin/survey-settings",
          "POST /api/admin/survey-settings",
          "GET /api/admin/survey-settings/:id",
          "PUT /api/admin/survey-settings/:id",
          "DELETE /api/admin/survey-settings/:id",
          "PATCH /api/admin/survey-settings/:id/toggle",
          "POST /api/admin/survey-settings/initialize"
        ],
        "used_by": ["server.js"]
      },
      "adminRouter.js": {
        "imports": ["../models"],
        "exports": [
          "GET /api/settings/survey-enabled",
          "PUT /api/settings/survey-enabled"
        ],
        "used_by": ["server.js"]
      }
