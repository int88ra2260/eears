{
  "project": {
    "name": "預約系統",
    "description": "React 18 + Bootstrap 5 前端、Node.js/Express 後端、Sequelize + MySQL、JWT、Excel 匯出、Email 通知、統計圖表",
    "version": "1.0.0"
  },
  "backend": {
    "entry": "server.js",
    "dependencies": {
      "express": "^4.21.2",
      "sequelize": "^6.37.6",
      "mysql2": "^3.13.0",
      "jsonwebtoken": "^9.0.2",
      "bcrypt": "^5.1.1",
      "cors": "^2.8.5",
      "dotenv": "^16.4.7",
      "exceljs": "^4.4.0",
      "nodemailer": "^6.10.0",
      "zod": "^4.0.17"
    },
    "routes": {
      "loginRouter.js": {
        "imports": ["../middlewares/auth", "jsonwebtoken"],
        "exports": ["POST /api/login"],
        "used_by": ["server.js"]
      },
      "eventRouter.js": {
        "imports": ["../middlewares/auth", "../models", "../utils/errorMessages", "dayjs", "exceljs"],
        "exports": [
          "GET /api/events",
          "GET /api/events/:id",
          "GET /api/reports/summary",
          "GET /api/events/:id/reservations",
          "GET /api/events/:id/export",
          "GET /api/reports/export",
          "POST /api/events",
          "DELETE /api/events/:id",
          "DELETE /api/events/:id/force-delete",
          "PUT /api/events/:id",
          "POST /api/events/:id/checkin",
          "POST /api/events/:id/violations",
          "GET /api/events/:id/violations",
          "POST /api/events/:id/auto-check"
        ],
        "used_by": ["server.js"]
      },
      "reservationRouter.js": {
        "imports": ["../models", "../middlewares/auth", "../middlewares/checkSurvey", "../utils/reservationTime", "../utils/validators", "../config/email", "dayjs"],
        "exports": [
          "POST /api/reservations",
          "DELETE /api/reservations/:id",
          "GET /api/reservations/public",
          "GET /api/reservations"
        ],
        "used_by": ["server.js"]
      },
      "blacklistRouter.js": {
        "imports": ["../models", "../middlewares/auth"],
        "exports": ["GET /api/blacklist", "POST /api/blacklist/recordViolation", "DELETE /api/blacklist/:id"],
        "used_by": ["server.js"]
      },
      "settingsRouter.js": {
        "imports": ["../models", "../middlewares/auth"],
        "exports": ["GET /api/settings/survey-required", "PUT /api/settings/survey-required"],
        "used_by": ["server.js"]
      },
      "englishTableSurveyRouter.js": {
        "imports": ["../models", "../middlewares/auth", "exceljs"],
        "exports": [
          "GET /api/survey/check/:studentId",
          "POST /api/survey/english-table",
          "GET /api/survey/export",
          "DELETE /api/survey/english-table/all",
          "DELETE /api/survey/english-table/:studentId",
          "GET /api/survey/stats"
        ],
        "used_by": ["server.js"]
      },
      "surveyRouter.js": {
        "imports": ["../models", "../middlewares/auth", "exceljs", "../surveys.json"],
        "exports": [
          "POST /api/surveys/:surveyId",
          "GET /api/surveys/check/:surveyId/:studentId",
          "GET /api/surveys/stats/:surveyId",
          "GET /api/surveys/export/:surveyId"
