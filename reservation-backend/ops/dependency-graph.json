      "EnglishClubSurveyResponse.js": {
        "imports": ["sequelize"],
        "exports": ["EnglishClubSurveyResponse"],
        "used_by": ["models/index.js", "routes/surveyRouter.js"]
      },
      "SurveySettings.js": {
        "imports": ["sequelize"],
        "exports": ["SurveySettings"],
        "used_by": ["models/index.js", "routes/surveySettingsRouter.js"]
      }
    },
    "middlewares": {
      "auth.js": {
        "imports": ["jsonwebtoken", "../utils/errorMessages"],
        "exports": ["authMiddleware", "adminMiddleware", "workerMiddleware", "workerOnlyMiddleware", "secretKey"],
        "used_by": ["routes/loginRouter.js", "routes/eventRouter.js", "routes/reservationRouter.js", "routes/blacklistRouter.js", "routes/settingsRouter.js", "routes/englishTableSurveyRouter.js", "routes/surveyRouter.js", "routes/surveySettingsRouter.js"]
