      },
      "Reservation.js": {
        "imports": ["sequelize"],
        "exports": ["Reservation"],
        "used_by": ["models/index.js", "routes/eventRouter.js", "routes/reservationRouter.js"]
      },
      "BlackListRecord.js": {
        "imports": ["sequelize"],
        "exports": ["BlackListRecord"],
        "used_by": ["models/index.js", "routes/blacklistRouter.js", "routes/eventRouter.js"]
