      "EnglishTableSurvey.js": {
        "imports": ["sequelize"],
        "exports": ["EnglishTableSurveyResponse"],
        "used_by": ["models/index.js", "routes/englishTableSurveyRouter.js", "routes/surveyRouter.js"]
