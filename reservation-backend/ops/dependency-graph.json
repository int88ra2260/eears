        "imports": ["sequelize"],
        "exports": ["Settings"],
        "used_by": ["models/index.js", "routes/settingsRouter.js", "routes/adminRouter.js"]
      },
      "SystemSettings.js": {
        "imports": ["sequelize"],
        "exports": ["SystemSettings"],
        "used_by": ["models/index.js"]
      },
      "EventViolation.js": {
        "imports": ["sequelize"],
        "exports": ["EventViolation"],
        "used_by": ["models/index.js", "routes/eventRouter.js"]
