# 日誌級別設定
# 可選值：DEBUG, INFO, WARN, ERROR, NONE
# DEBUG: 顯示所有日誌（包括詳細調試資訊）
# INFO: 顯示一般資訊、警告和錯誤（推薦生產環境）
# WARN: 只顯示警告和錯誤
# ERROR: 只顯示錯誤
# NONE: 不輸出任何日誌
LOG_LEVEL=INFO

# SystemLog（DB）減量：僅影響 system_logs 表，不影響 console / 管理端記憶體近期摘要
# 成功 GET/HEAD 依機率寫入；錯誤（status≥）、慢請求、/api/admin、POST/PUT/PATCH/DELETE 仍全寫
# 生產可設 0.1～0.25；開發可設 1
SYSTEM_LOG_GET_SAMPLE_RATE=1
# 超過此耗時（毫秒）一律寫入
SYSTEM_LOG_SLOW_MS=4000
# status 大於等於此值一律寫入（預設 400）
SYSTEM_LOG_ALWAYS_STATUS_MIN=400
# 可選：逗號分隔路徑前綴，成功 GET 幾乎不寫（除非錯誤／慢／管理端），適合輪詢 API
# SYSTEM_LOG_SKIP_PATH_PREFIXES=/api/example/poll
# 上列前綴內成功 GET 的額外抽樣率（0＝全跳過、1＝等同一般 GET 規則）
# SYSTEM_LOG_SKIP_PREFIX_GET_SAMPLE_RATE=0

# 稽核：登入失敗合併寫入間隔（毫秒）。0＝每筆立即寫；預設 5000 內同 IP 合併一筆
# AUDIT_LOGIN_FAILURE_AGGREGATE_MS=5000

# Learning Journey v3 read model（預設 false；Phase 5-9 預備，正式切換 V2 讀源前再啟用）
ENABLE_LEARNING_JOURNEY_V3_READ_MODEL=false

# 英檢長期追蹤（可選）
# ENABLE_ENGLISH_TEST_TRACKING=true
# ENGLISH_TEST_TRACKING_IMPORT_OVERWRITE_ENROLLMENT=false
# ENGLISH_TEST_TRACKING_BEST_TIEBREAKER=cefr,rawScore,testDate,attemptId
